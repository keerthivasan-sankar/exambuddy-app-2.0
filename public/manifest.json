{
  "id": "/?source=pwa",
  "name": "Exam Buddy",
  "short_name": "Exam Buddy",
  "description": "Student travel coordination platform for exam centers.",
  "start_url": "/?source=pwa",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "lang": "en",
  "dir": "ltr",
  "scope": "/",
  "categories": ["education", "travel", "productivity"],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.exambuddy.app",
      "id": "com.exambuddy.app"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot_desktop.jpg",
      "sizes": "1376x768",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "ExamBuddy Home Dashboard"
    },
    {
      "src": "/screenshot_mobile.jpg",
      "sizes": "768x1376",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "ExamBuddy Mobile Dashboard"
    }
  ],
  "shortcuts": [
    {
      "name": "Find Rides",
      "short_name": "Rides",
      "description": "Find available rides to exam centers",
      "url": "/rides",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "My Profile",
      "short_name": "Profile",
      "description": "View and edit your profile",
      "url": "/profile",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/csv": [".csv"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+exambuddy",
      "url": "/?action=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "ExamBuddy Quick Rides",
      "description": "Quickly see available rides",
      "tag": "exambuddy-rides-widget",
      "template_url": "/widget.json",
      "type": "application/json",
      "action": "/widget",
      "delay": 1000,
      "ms_ac_template": "/widget.json",
      "ms_ac_data": "/widget-data.json",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  }
}
